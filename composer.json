{
    "name": "esfredderick/useful-artisan-commands",
    "description": "A collection of useful Laravel Artisan commands for generating actions, DTOs, and more.",
    "keywords": ["laravel", "artisan", "commands", "actions", "dto"],
    "license": "MIT",
    "authors": [
        {
            "name": "Sebastián Montero",
            "email": "esfredderick@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^12.0|^13.0",
        "illuminate/database": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0",
        "laravel/prompts": "^0.3|^1.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.8|^4.0"
    },
    "autoload": {
        "psr-4": {
            "EsFredDerick\\UsefulArtisanCommands\\": "src/"
        }
    },
    "scripts": {
        "test": "pest"
    },
    "extra": {
        "laravel": {
            "providers": [
                "EsFredDerick\\UsefulArtisanCommands\\UsefulArtisanCommandsServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
